;; -*- mode: emacs-lisp; coding: utf-8-unix -*-
;; Minibuffer history file, automatically generated by ‘savehist’.

(setq savehist-minibuffer-history-variables '(evil-ex-history extended-command-history))
(setq evil-ex-history '(#("w" 0 1 (ex-index 1))))
(setq extended-command-history '("eval-buffer"))
(setq evil-jumps-history 'nil)
